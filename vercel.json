{
  "version": 2,
  "routes": [
    {
      "src": "/install.sh",
      "dest": "/install.sh",
      "headers": {
        "Content-Type": "application/x-sh"
      }
    },
    {
      "src": "/cheatsheet.sh",
      "dest": "/cheatsheet.sh",
      "headers": {
        "Content-Type": "application/x-sh"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    }
  ]
}
